[Unit]
Description=Update De-Koi Pi containers from the newest successful image batch
Wants=network-online.target docker.service
After=network-online.target docker.service

[Service]
Type=oneshot
User=chai
WorkingDirectory=/home/chai/de-koi-src
StateDirectory=de-koi
EnvironmentFile=-/etc/de-koi/pi-update.env
ExecStart=/usr/bin/flock %S/de-koi/pi-update.lock /bin/sh scripts/pi-update.sh --trusted-lan
