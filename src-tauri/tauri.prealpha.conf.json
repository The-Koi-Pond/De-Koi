{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "De-Koi Pre-Alpha",
  "identifier": "com.de-koi.prealpha",
  "app": {
    "windows": [
      {
        "title": "De-Koi Pre-Alpha",
        "width": 800,
        "height": 600,
        "center": true,
        "dragDropEnabled": false,
        "decorations": false,
        "resizable": true,
        "minWidth": 720,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**",
          "$APPDATA/.avatar-thumbnails/**",
          "$APPDATA/.managed-thumbnails/**",
          "$APPLOCALDATA/**",
          "$APPLOCALDATA/.avatar-thumbnails/**",
          "$APPLOCALDATA/.managed-thumbnails/**",
          "$APPCONFIG/**",
          "$APPCONFIG/.avatar-thumbnails/**",
          "$APPCONFIG/.managed-thumbnails/**"
        ]
      }
    }
  }
}
